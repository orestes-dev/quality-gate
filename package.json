{
  "name": "issue-quality-gate",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic quality gate for GitHub issues so they land well-scoped and actionable.",
  "author": "Orestes Carracedo <orestes@orestes.io>",
  "type": "module",
  "packageManager": "yarn@4.16.0",
  "bin": "bin/cli.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,md,yml,yaml,json}": "prettier --write"
  }
}
